# ── Flat Parser — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# ── Telegram ─────────────────────────────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_TOKEN=your_bot_token_here
# Your channel username (e.g. @my_channel) or channel ID (e.g. -1001234567890)
TELEGRAM_CHANNEL=@your_channel_username

# ── Environment ──────────────────────────────────────────────────────────────
# development (default): test_mode=true → notifications to console
# production: test_mode=false → notifications to Telegram
FLAT_ENV=development

# ── vLLM (for docker-compose) ────────────────────────────────────────────────
# Hugging Face token (optional, for gated models)
# HUGGING_FACE_HUB_TOKEN=hf_...
# Model to use
VLLM_MODEL=Qwen/Qwen2.5-32B-Instruct
# GPU count for tensor parallelism
VLLM_GPU_COUNT=1
VLLM_TENSOR_PARALLEL=1
